                      Most Popular
                    </span>
                  )}
                  <h4
                    style={`font-size:1.125rem;font-family:var(--font-heading);margin-bottom:0.5rem;color:${best ? "white" : "var(--color-navy)"};`}
                  >
                    {name} Plan
                  </h4>
                  <p
                    style={`font-size:0.875rem;margin:0;color:${best ? "rgba(255,255,255,0.75)" : "var(--color-text-muted)"};`}
