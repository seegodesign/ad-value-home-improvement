        </div>
      </div>
    </div>
  </section>
     */
  }

  <CTASection
    eyebrow="Don't Wait"
    title="Request a Free Estimate Today"
    subtitle="Whether it's a small repair or a major remodel, we're ready to help."
    primaryLabel="Request a Free Estimate"
    secondaryLabel={settings.phone}
    secondaryHref={phoneHref}
  />
</BaseLayout>

<style>
  @media (min-width: 900px) {
    .care-plan-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
