---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import settings from "../data/settings.json";

const phoneHref = `tel:+1${settings.phone.replace(/\D/g, "")}`;

const careIncludes = [
  "Gutter cleaning & debris clearing",
  "Exterior property inspection report",
  "Deck surface & structural inspection",
  "Fence & gate condition check",
  "Pressure washing discounts (10–20%)",
  "Priority scheduling over non-members",
  "Post-storm damage checkup",
];

const carePlans = [
  {
    name: "Monthly",
    desc: "Full care every month. Ideal for vacation rentals & high-traffic homes.",
    best: false,
  },
  {
    name: "Quarterly",
    desc: "Seasonal visits to catch issues before they become problems.",
    best: true,
  },
  {
    name: "Annual",
    desc: "One thorough inspection per year. Great starting point.",
    best: false,
  },
];
const sent = Astro.url.searchParams.get("sent") === "true";
---

<BaseLayout
  title="Contact | Ad Value Home Improvement Kauai"
  description="Contact Ad Value Home Improvement on Kauai. Call, email, or fill out a form. Serving Lihue, Kapaa, Princeville, Poipu, Hanapepe, and all of Kauai."
>
  <Fragment slot="head"
    ><script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script></Fragment
  >
  <!-- Success banner -->
  {
    sent && (
      <div
        role="alert"
        style="background:var(--color-success,#2e7d32);color:#fff;text-align:center;padding:1rem;font-weight:600;"
      >
        Message sent! We'll be in touch within 1 business day.
      </div>
    )
  }

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>Contact</span>
      </nav>
      <p class="page-hero__eyebrow">We'd Love to Hear From You</p>
      <h1 class="page-hero__title">Contact Us</h1>
      <p class="page-hero__subtitle">
        Get in touch and Adam will respond within 1 business day. You'll always
        talk to the person doing the work.
      </p>
    </div>
  </section>

  <!-- Contact Info Grid -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container contact-info">
      <!-- Left: contact details + map -->
      <div style="display:flex;flex-direction:column;gap:2rem;">
        <div class="contact-info__card">
          <h2 id="contact-heading" class="contact-info__title">Get In Touch</h2>

          <div class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <span class="icon-mask icon-phone icon-md"></span>
            </div>
            <div class="contact-info__item-content">
              <p class="contact-info__item-label">Phone</p>
              <p class="contact-info__item-value">
                <a href={phoneHref}>{settings.phone}</a>
              </p>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <span class="icon-mask icon-email icon-md"></span>
            </div>
            <div class="contact-info__item-content">
              <p class="contact-info__item-label">Email</p>
              <p class="contact-info__item-value">
                <a href={`mailto:${settings.email}`}>{settings.email}</a>
              </p>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <span class="icon-mask icon-location icon-md"></span>
            </div>
            <div class="contact-info__item-content">
              <p class="contact-info__item-label">Location</p>
              <p class="contact-info__item-value">Lihue, Kauai, Hawaii 96766</p>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <span class="icon-mask icon-clock icon-md"></span>
            </div>
            <div class="contact-info__item-content">
              <p class="contact-info__item-label">Business Hours</p>
              <p class="contact-info__item-value">{settings.hours.weekdays}</p>
              <p class="contact-info__item-value">{settings.hours.saturday}</p>
              <p
                class="contact-info__item-value"
                style="color:var(--color-text-muted);font-size:0.875rem;"
              >
                {settings.hours.sunday}
              </p>
            </div>
          </div>
        </div>
        <!-- Service Areas -->
        <div class="contact-info__card">
          <h2 class="contact-info__title">Service Areas</h2>
          <p
            style="font-size:0.9375rem;color:var(--color-text-muted);margin-bottom:1.25rem;"
          >
            We serve homeowners across Kauai, including:
          </p>
          <div class="service-areas">
            {
              settings.serviceAreas.map((area) => (
                <span class="service-area-badge">{area}</span>
              ))
            }
          </div>
          <p
            style="font-size:0.8125rem;color:var(--color-text-muted);margin-top:1.25rem;"
          >
            Not on this list? Call us — we likely serve your area too.
          </p>
        </div>
      </div>

      <!-- Right: Quick form + service areas -->
      <div style="display:flex;flex-direction:column;gap:2rem;">
        <!-- Quick Contact Form -->
        <div class="contact-info__card">
          <h2 class="contact-info__title">Send a Message</h2>
          <form
            action="https://submit-form.com/mLcpka6Fj"
            name="contact"
            method="POST"
            style="display:flex;flex-direction:column;gap:1.25rem;"
          >
            <input
              type="hidden"
              name="_redirect"
              value="https://advaluekauai.com/contact?sent=true"
            />
            <p style="display:none;" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            <input type="hidden" name="form-name" value="contact" />

            <div class="estimate-form__group">
              <label
                for="cn-name"
                class="estimate-form__label estimate-form__label--required"
                >Name</label
              >
              <input
                id="cn-name"
                type="text"
                name="name"
                class="estimate-form__input"
                placeholder="Your name"
                required
              />
            </div>
            <div class="estimate-form__group">
              <label
                for="cn-email"
                class="estimate-form__label estimate-form__label--required"
                >Email</label
              >
              <input
                id="cn-email"
                type="email"
                name="email"
                class="estimate-form__input"
                placeholder="you@example.com"
                required
              />
            </div>
            <div class="estimate-form__group">
              <label for="cn-phone" class="estimate-form__label">Phone</label>
              <input
                id="cn-phone"
                type="tel"
                name="phone"
                class="estimate-form__input"
                placeholder={settings.phone}
              />
            </div>
            <div class="estimate-form__group">
              <label
                for="cn-message"
                class="estimate-form__label estimate-form__label--required"
                >Message</label
              >
              <textarea
                id="cn-message"
                name="message"
                class="estimate-form__textarea"
                rows="4"
                placeholder="Tell us how we can help..."
                required></textarea>
            </div>
            <div class="cf-turnstile" data-sitekey="0x4AAAAAADtRmInV5QcyiO91">
            </div>
            <button type="submit" class="btn btn--primary btn--full"
              >Send Message</button
            >
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Aloha Home Care Plan -->
  {
    /*
  <section
    class="section section--sand"
    id="care-plan"
    aria-labelledby="care-plan-heading"
  >
    <div class="container">
