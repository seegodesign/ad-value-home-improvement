        <span class="section__eyebrow">Recurring Service Membership</span>
        <h2 id="care-plan-heading" class="section__title">
          The Aloha Home Care Plan
        </h2>
        <p class="section__subtitle">
          Year-round property maintenance so your home is always protected,
          maintained, and ready — no matter the season.
        </p>
      </div>

      <div
        style="display:grid;gap:3rem;align-items:start;"
        class="care-plan-grid"
      >
        <!-- What's included -->
        <div>
          <h3
            style="font-size:1.25rem;color:var(--color-navy);margin-bottom:1.5rem;"
          >
            Every Plan Includes:
          </h3>
          <div style="display:flex;flex-direction:column;gap:0.875rem;">
            {
              careIncludes.map((item) => (
                <div style="display:flex;align-items:flex-start;gap:0.875rem;padding:0.875rem;background:white;border-radius:var(--radius);border:1px solid var(--color-gray-200);">
                  <span
                    class="icon-mask icon-check"
                    style="width:18px;height:18px;color:var(--color-green);flex-shrink:0;"
                  />
                  <span style="font-size:0.9375rem;color:var(--color-text-muted);">
                    {item}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Plans -->
        <div>
          <h3
            style="font-size:1.25rem;color:var(--color-navy);margin-bottom:1.5rem;"
          >
