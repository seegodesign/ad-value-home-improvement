---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import CTASection from '../components/CTASection.astro';
import reviews from '../data/reviews.json';

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Ad Value Home Improvement',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: reviews.length.toString(),
    bestRating: '5',
    worstRating: '1',
  },
  review: reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: r.stars.toString(),
      bestRating: '5',
    },
    reviewBody: r.text,
  })),
};
---

<BaseLayout
  title="Client Reviews | Ad Value Home Improvement Kauai"
  description="Read 5-star reviews from Kauai homeowners who have worked with Ad Value Home Improvement. Trusted contractor for decks, remodels, fencing, and more."
  schema={reviewSchema}
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>Reviews</span>
      </nav>
      <p class="page-hero__eyebrow">What Our Clients Say</p>
      <h1 class="page-hero__title">Our Reviews Speak For Themselves</h1>
      <p class="page-hero__subtitle">
        Real reviews from real Kauai homeowners. We're proud of what they say — and humbled by their trust.
      </p>
      <div class="page-hero__accent-bar" aria-hidden="true"></div>
    </div>
  </section>

  <!-- Overall Rating -->
  <section class="section section--sand section--sm">
    <div class="container">
      <div style="display:flex;flex-wrap:wrap;gap:2rem;align-items:center;justify-content:center;text-align:center;">
        <div>
          <p style="font-family:var(--font-heading);font-size:5rem;font-weight:800;color:var(--color-navy);line-height:1;">5.0</p>
          <p style="font-size:2rem;color:#f5c842;letter-spacing:2px;">★★★★★</p>
          <p style="font-size:0.875rem;color:var(--color-text-muted);margin-top:0.5rem;">
            Based on {reviews.length} verified reviews
          </p>
        </div>
        <div style="width:1px;height:80px;background:var(--color-gray-300);display:none;" class="divider-v" aria-hidden="true"></div>
        <div>
          <p style="font-family:var(--font-heading);font-size:1.25rem;font-weight:700;color:var(--color-navy);margin-bottom:1rem;">
            What homeowners say about us:
          </p>
          <div style="display:flex;flex-direction:column;gap:0.625rem;">
            {['Showed up on time', 'Quality craftsmanship', 'Clear communication', 'Honest pricing', 'Cleaned up after'].map((item) => (
              <div style="display:flex;align-items:center;gap:0.625rem;font-size:0.9375rem;color:var(--color-text-muted);">
                <span style="color:var(--color-green);font-weight:700;">✓</span>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Reviews -->
  <section class="section" aria-labelledby="reviews-heading">
    <div class="container">
      <div class="section__header">
        <span class="section__eyebrow">All Reviews</span>
        <h2 id="reviews-heading" class="section__title">Trusted by Kauai Homeowners</h2>
      </div>
      <div class="grid grid--3">
        {reviews.map((review) => (
          <ReviewCard
            name={review.name}
            neighborhood={review.neighborhood}
            text={review.text}
            photo={review.photo}
            stars={review.stars}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Leave a review prompt -->
  <section class="section section--sand section--sm">
    <div class="container" style="text-align:center;max-width:680px;">
      <span class="section__eyebrow">Share Your Experience</span>
      <h2 style="font-size:1.75rem;color:var(--color-navy);margin-bottom:1rem;">
        Were You Happy With Our Work?
      </h2>
      <p style="color:var(--color-text-muted);margin-bottom:2rem;">
        Your review helps Kauai homeowners find a contractor they can trust.
        We'd be honored if you'd share your experience.
      </p>
      <a
        href="https://g.page/r/review"
        class="btn btn--primary btn--lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        Leave a Google Review ↗
      </a>
    </div>
  </section>

  <CTASection
    eyebrow="Join Our Happy Clients"
    title="Ready to Experience the Difference?"
    subtitle="Get an honest estimate from the contractor Kauai homeowners rave about."
    primaryLabel="Request a Free Estimate"
    secondaryLabel="View Our Work"
    secondaryHref="/gallery"
  />
</BaseLayout>

<style>
  @media (min-width: 768px) {
    .divider-v { display: block !important; }
  }
</style>
