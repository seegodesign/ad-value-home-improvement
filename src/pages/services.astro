---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import services from '../data/services.json';
import settings from '../data/settings.json';

const serviceDetails = {
  decks: {
    href: '/deck-builder-kauai',
    fullList: ['Trex Composite Decks', 'Ipe Hardwood Decks', 'Deck Repairs & Restoration', 'Railings & Balusters', 'Stairs & Landings', 'Custom Deck Designs', 'Post & Beam Pergolas'],
  },
  carpentry: {
    href: '/custom-carpentry-kauai',
    fullList: ['Finish Carpentry', 'Custom Built-ins', 'Door Installation', 'Window & Slider Installation', 'Hardwood & Tile Flooring', 'Trim & Crown Molding', 'Siding Repair & Replacement', 'Framing', 'Wood Repairs', 'Chicken Coops', 'Farm Stands', 'Horse Mounting Blocks'],
  },
  kitchens: {
    href: '/kitchen-remodel-kauai',
    fullList: ['Cabinet Installation & Refacing', 'Countertop Fabrication & Install', 'Backsplash Tile', 'Flooring', 'Appliance Hook-up', 'Design Services'],
  },
  bathrooms: {
    href: '/bathroom-remodel-kauai',
    fullList: ['Tile Installation', 'Vanity Installation', 'Shower & Tub Remodel', 'Mirrors & Towel Racks', 'Water Damage Repair', 'Design Services'],
  },
  drywall: {
    href: '/drywall-repair-kauai',
    fullList: ['Drywall Repairs', 'Texture Matching', 'Interior Painting', 'Exterior Painting', 'Trim Painting', 'Deck Staining & Sealing'],
  },
  fencing: {
    href: '/fence-contractor-kauai',
    fullList: ['Cedar Fencing', 'Ipe Hardwood Fencing', 'Hog Wire Fencing', 'Chain Link Fencing', 'Bamboo Fencing', 'Custom Gates', 'Privacy Fencing', 'Split Rail'],
  },
  maintenance: {
    href: '/property-maintenance-kauai',
    fullList: ['Rental Turnovers', 'Pressure Washing', 'General Repairs', 'Maintenance Packages', 'Garage Organization', 'Gutter Cleaning'],
  },
  outdoor: {
    href: '/services',
    fullList: ['Pergolas', 'Covered Patios', 'Garden Features', 'Walkways & Pathways', 'Exterior Stairs', 'Outdoor Showers', 'Facelifts & Upgrades'],
  },
};

const serviceImages: Partial<Record<string, string>> = {
  decks: '/images/uploads/deck-builder.avif',
  carpentry: '/images/uploads/custom_1.avif',
  kitchens: '/images/uploads/kitchen-remodel.avif',
  bathrooms: '/images/uploads/bathroom-remodel.avif',
  drywall: '/images/uploads/drywall-repair.avif',
  fencing: '/images/uploads/fence-contractor.avif',
  maintenance: '/images/uploads/property-maintenance.avif',
  outdoor: '/images/uploads/outdoor-living.avif',
};

const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
---

<BaseLayout
  title="Home Improvement Services Kauai | Ad Value Home Improvement"
  description="Full-service home improvement on Kauai. Decks, fencing, kitchen & bathroom remodels, custom carpentry, drywall, painting, property maintenance, and outdoor living."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>Services</span>
      </nav>
      <p class="page-hero__eyebrow">Full-Service Home Improvement</p>
      <h1 class="page-hero__title">What We Build, Repair &amp; Maintain</h1>
      <p class="page-hero__subtitle">
        From a single repair to a complete remodel — quality work, honestly priced, delivered on time.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section__header">
        <span class="section__eyebrow">Our Services</span>
        <h2 id="services-heading" class="section__title">Everything Your Home Needs</h2>
        <p class="section__subtitle">
          Whether you're building, renovating, or maintaining — we have the skills and experience to do it right.
        </p>
      </div>

      <div style="display:flex;flex-direction:column;gap:5rem;max-width: var(--max-width);margin:0 auto;">
        {services.map((service) => {
          const details = serviceDetails[service.id as keyof typeof serviceDetails];
          const imageSrc = serviceImages[service.id] || '/images/placeholder-project.svg';
          return (
            <div
              id={service.id}
              style="display:grid;gap:3rem;align-items:start;"
              class="services-detail-row"
            >
              <div>
                <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">
                  {/* <div style="width:56px;height:56px;background:var(--color-sand);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <img src={service.icon} alt="" width="28" height="28" aria-hidden="true" />
                  </div> */}
                  <h2 style="font-size:1.75rem;color:var(--color-navy);">{service.title}</h2>
                </div>
                <span class="accent-bar" aria-hidden="true"></span>
                <p style="font-size:1.0625rem;color:var(--color-text-muted);line-height:1.8;margin-bottom:1.5rem;">
                  {service.description}
                </p>
                {details?.href && details.href !== '/services' && (
                  <a href={details.href} class="btn btn--primary btn--sm" style="margin-bottom:1.5rem;">
                    {service.title} Details →
                  </a>
                )}
              </div>

              <div style="background:var(--color-off-white);border-radius:var(--radius-lg);padding:2rem;border:1px solid var(--color-gray-200);">
                <div style="border-radius:var(--radius);overflow:hidden;aspect-ratio:16/10;margin-bottom:1rem;">
                  <img
                    src={imageSrc}
                    alt={service.title}
                    width="640"
                    height="400"
                    loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;display:block;"
                  />
                </div>
                <h3 style="font-size:1rem;color:var(--color-navy);margin-bottom:1rem;text-transform:uppercase;letter-spacing:0.08em;font-size:0.75rem;">
                  Services Include
                </h3>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.625rem;">
                  {(details?.fullList || service.items).map((item) => (
                    <div style="display:flex;align-items:center;gap:0.625rem;font-size:0.9375rem;color:var(--color-text-muted);">
                      <span style="color:var(--color-green);font-weight:700;flex-shrink:0;">✓</span>
                      {item}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Aloha Care Plan callout -->
  {
    /*
    <section class="section care-callout" aria-labelledby="care-heading">
      <div class="container">
        <div class="care-callout__card">
          <span class="care-callout__badge">New: Recurring Service</span>
          <h2 id="care-heading" class="care-callout__title">The Aloha Home Care Plan</h2>
          <p class="care-callout__subtitle">
            Year-round property maintenance so small issues never become big problems. Choose the cadence that works for you.
          </p>
          <div class="care-callout__tiers">
            <div class="care-callout__tier">
              <span class="care-callout__tier-name">Monthly</span>
              <span class="care-callout__tier-label">Ongoing peace of mind</span>
            </div>
            <div class="care-callout__divider" aria-hidden="true"></div>
            <div class="care-callout__tier">
              <span class="care-callout__tier-name">Quarterly</span>
              <span class="care-callout__tier-label">Seasonal check-ins</span>
            </div>
            <div class="care-callout__divider" aria-hidden="true"></div>
            <div class="care-callout__tier">
              <span class="care-callout__tier-name">Annual</span>
              <span class="care-callout__tier-label">One visit per year</span>
            </div>
          </div>
          <ul class="care-callout__perks">
            {['Priority scheduling', 'Gutter cleaning', 'Deck &amp; fence inspections', 'Storm damage checkups'].map((perk) => (
              <li class="care-callout__perk" set:html={`<span aria-hidden="true">✓</span> ${perk}`}></li>
            ))}
          </ul>
          <a href="/contact#care-plan" class="btn btn--primary btn--lg care-callout__cta">
            Learn About the Care Plan →
          </a>
        </div>
      </div>
    </section>
    */
  }
  <CTASection
    eyebrow="Get Started"
    title="Request a Free Estimate"
    subtitle="Tell us about your project and we'll be in touch within 1 business day."
    primaryLabel="Request a Free Estimate"
    secondaryLabel={settings.phone}
    secondaryHref={phoneHref}
  />
</BaseLayout>

<style>
  @media (min-width: 768px) {
    .services-detail-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ---- Aloha Care Plan callout ---- */
  .care-callout {
    position: relative;
    overflow: hidden;
    background-color: #14355a;
    background-image:
      linear-gradient(rgba(164, 206, 255, 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(164, 206, 255, 0.18) 1px, transparent 1px),
      linear-gradient(rgba(214, 236, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(214, 236, 255, 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgba(20, 53, 90, 0.95), rgba(12, 32, 54, 0.98));
    background-size: 64px 64px, 64px 64px, 16px 16px, 16px 16px, auto;
    background-position: -1px -1px, -1px -1px, -1px -1px, -1px -1px, center;
    padding-block: clamp(4.5rem, 9vw, 7rem);
  }

  .care-callout::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5, 14, 24, 0.66), rgba(5, 14, 24, 0.8));
    pointer-events: none;
  }

  .care-callout .container {
    position: relative;
    z-index: 1;
  }

  .care-callout__card {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-9);
  }

  .care-callout__badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brown-light);
    border: 1px solid rgba(185, 133, 77, 0.45);
    padding: var(--sp-3) var(--sp-5);
    border-radius: var(--radius-full);
  }

  .care-callout__title {
    font-size: clamp(2.4rem, 5vw, 3.5rem);
    font-weight: var(--fw-extrabold);
    line-height: 1.1;
    color: var(--color-white);
    margin: 0;
  }

  .care-callout__subtitle {
    font-size: var(--fs-lg);
    color: rgba(255,255,255,0.78);
    line-height: 1.75;
    max-width: 64ch;
    margin: 0;
    padding-top: var(--sp-4);
    padding-bottom: var(--sp-8);
  }

  .care-callout__tiers {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-6);
    width: 100%;
    padding: var(--sp-8) var(--sp-6);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
  }

  .care-callout__divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.18);
    flex-shrink: 0;
  }

  .care-callout__tier {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-1);
    flex: 1;
  }

  .care-callout__tier-name {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--fw-extrabold);
    color: var(--color-white);
  }

  .care-callout__tier-label {
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.58);
    letter-spacing: 0.04em;
  }

  .care-callout__perks {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-3) var(--sp-5);
    list-style: none;
    margin: 0 0 var(--sp-6) 0;
    padding-block: var(--sp-2);
    padding-inline: 0;
  }

  .care-callout__perk {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: rgba(255,255,255,0.82);
  }

  .care-callout__perk span {
    color: var(--color-green-light);
    font-size: var(--fs-base);
  }

  .care-callout__cta {
    margin-top: var(--sp-4);
  }
</style>
