---
import BaseLayout from '../layouts/BaseLayout.astro';
import EstimateForm from '../components/EstimateForm.astro';
import settings from '../data/settings.json';

const steps = [
  { n: '1', title: 'Submit Your Request', desc: 'Fill out the form with your project details. Takes about 2 minutes.' },
  { n: '2', title: 'Adam Gets in Touch', desc: 'Within 1 business day, Adam will call or text to discuss your project.' },
  { n: '3', title: 'On-Site Visit', desc: 'Adam visits your property to assess the project and answer all your questions.' },
  { n: '4', title: 'Detailed Estimate', desc: 'You receive a written estimate with a clear scope, timeline, and pricing.' },
];

const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
---

<BaseLayout
  title="Request a Free Estimate | Ad Value Home Improvement Kauai"
  description="Request a free home improvement estimate from Ad Value Home Improvement on Kauai. Fast response, no obligation. Decks, remodels, fencing, carpentry, and more."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>Request Estimate</span>
      </nav>
      <p class="page-hero__eyebrow">No Pressure, No Obligation</p>
      <h1 class="page-hero__title">Request a Free Estimate</h1>
      <p class="page-hero__subtitle">
        Tell us about your project. We'll be in touch within 1 business day.
      </p>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="section section--wood section--sm" aria-label="How the estimate process works">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
        {steps.map(({ n, title, desc }) => (
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:0.75rem;">
            <div style="width:48px;height:48px;background:var(--color-navy);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-heading);font-weight:800;font-size:1.125rem;flex-shrink:0;">
              {n}
            </div>
            <h3 style="font-size:1rem;color:var(--color-navy);">{title}</h3>
            <p style="font-size:0.875rem;line-height:1.6;margin:0;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form + Sidebar -->
  <section class="section" aria-labelledby="estimate-heading">
    <div class="container" style="display:grid;gap:3rem;align-items:start;">
      <!-- Form -->
      <div>
        <EstimateForm />
      </div>

      <!-- Sidebar info -->
      <aside style="display:flex;flex-direction:column;gap:1.5rem;">
        <div style="background:var(--color-navy);color:white;border-radius:var(--radius-lg);padding:2rem;">
          <h3 style="font-size:1.25rem;color:white;margin-bottom:1rem;">Prefer to Call?</h3>
          <p style="color:rgba(255,255,255,0.8);font-size:0.9375rem;margin-bottom:1.25rem;">
            Adam answers his own phone. You'll always talk to the person doing the work.
          </p>
          <a href={phoneHref} class="btn btn--primary btn--full"><span class="icon-mask icon-phone icon-sm" style="margin-right:0.4rem;" aria-hidden="true"></span> {settings.phone}</a>
          <a href="mailto:info@advaluekauai.com" class="btn btn--outline-white btn--full" style="margin-top:0.75rem;">
            <span class="icon-mask icon-email icon-sm" style="margin-right:0.4rem;" aria-hidden="true"></span> Email Us
          </a>
        </div>

        <div style="background:var(--color-off-white);border-radius:var(--radius-lg);padding:2rem;border:1px solid var(--color-gray-200);">
          <h3 style="font-size:1rem;color:var(--color-navy);margin-bottom:1rem;">What to Include</h3>
          <ul style="display:flex;flex-direction:column;gap:0.625rem;">
            {['Your contact info', 'Project address', 'What you want done', 'Any photos if you have them', 'Rough timeline or urgency'].map((tip) => (
              <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:var(--color-text-muted);">
                <span class="icon-mask icon-check" style="width:14px;height:14px;color:var(--color-green);flex-shrink:0;"></span>
                {tip}
              </li>
            ))}
          </ul>
        </div>

        <div style="background:var(--color-sand);border-radius:var(--radius-lg);padding:1.5rem;border:1px solid var(--color-sand-dark);">
          <p style="font-size:0.875rem;color:var(--color-text-muted);line-height:1.7;margin:0;">
            <strong style="color:var(--color-navy);">★★★★★</strong><br/>
            "Adam responded within hours and came out the next day. The estimate was detailed
            and exactly what we expected. No hidden costs."
            <br/><span style="color:var(--color-brown);font-weight:600;">— Mike T., Lihue</span>
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  @media (min-width: 900px) {
    section[aria-labelledby="estimate-heading"] > div.container {
      grid-template-columns: 1fr 380px;
    }
  }
</style>
