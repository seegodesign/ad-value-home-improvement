---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import settings from '../data/settings.json';
import aboutData from '../data/about.json';

const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
const values = aboutData.values;
---

<BaseLayout
  title="About Adam Marchacos | Ad Value Home Improvement Kauai"
  description="Meet Adam Marchacos, owner of Ad Value Home Improvement. Kauai's trusted home improvement contractor since 2019. Learn about our values, craftsmanship, and commitment to the community."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>About</span>
      </nav>
      <p class="page-hero__eyebrow">Kauai's Trusted Contractor</p>
      <h1 class="page-hero__title">Meet Adam</h1>
      <p class="page-hero__subtitle">
        Honest work, skilled hands, and genuine aloha — built into every project.
      </p>
    </div>
  </section>

  <!-- Meet Adam -->
  <section class="section" aria-labelledby="adam-heading">
    <div class="container about-preview">
      <div class="about-preview__image">
        <div class="about-preview__photo-frame">
          <img
            src={aboutData.ownerPhoto}
            alt={`${aboutData.ownerName}, owner of Ad Value Home Improvement`}
            width="420"
            height="560"
            loading="eager"
          />
        </div>
        <div class="about-preview__photo-accent" aria-hidden="true"></div>
      </div>

      <div class="about-preview__content">
        <span class="section__eyebrow">Est. 2019 · Kauai, Hawaii</span>
        <h2 id="adam-heading" class="section__title">Aloha! I'm {aboutData.ownerName}</h2>
        <span class="accent-bar" aria-hidden="true"></span>

        {aboutData.bio.map((para, i) => (
          <p style="font-size:1.0625rem;line-height:1.8;color:var(--color-text-muted);margin-bottom:1.25rem;">
            {para}
          </p>
        ))}
        <p style="font-size:1.125rem;font-family:var(--font-heading);font-weight:700;color:var(--color-navy);margin-bottom:2rem;">
          {aboutData.signature}
        </p>

        <div class="about-preview__signature">
          <div>
            <p class="about-preview__sig-name">{aboutData.ownerName}</p>
            <p class="about-preview__sig-title">{aboutData.ownerTitle}</p>
          </div>
        </div>

        <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="/estimate" class="btn btn--primary">Request a Free Estimate</a>
          <a href={phoneHref} class="btn btn--outline-navy">{settings.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section--sand" aria-labelledby="values-heading">
    <div class="container">
      <div class="section__header">
        <span class="section__eyebrow">How We Work</span>
        <h2 id="values-heading" class="section__title">What We Stand For</h2>
        <p class="section__subtitle">
          These aren't just words — they're how we operate on every single job.
        </p>
      </div>
      <div class="grid grid--3">
        {values.map(({ icon, title, desc }) => (
          <div style="background:white;border-radius:var(--radius-lg);padding:2rem;box-shadow:var(--shadow-sm);border:1px solid var(--color-gray-200);">
            <div style="width:44px;height:44px;background:var(--color-sand);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;" aria-hidden="true">
              <span class="icon-mask" style={`-webkit-mask-image:url('/icons/${icon}.svg');mask-image:url('/icons/${icon}.svg');width:24px;height:24px;color:var(--color-navy);`}></span>
            </div>
            <h3 style="font-size:1.125rem;color:var(--color-navy);margin-bottom:0.75rem;">{title}</h3>
            <p style="font-size:0.9375rem;color:var(--color-text-muted);line-height:1.7;margin:0;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- By the Numbers -->
  <section class="section section--navy" aria-label="Key statistics">
    <div class="container">
      <div class="section__header">
        <span class="section__eyebrow">By the Numbers</span>
        <h2 class="section__title">Proven Track Record</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:2rem;text-align:center;">
        {aboutData.stats.map(({ number: n, label: l }) => (
          <div>
            <p style="font-family:var(--font-heading);font-size:2.5rem;font-weight:800;color:var(--color-brown-light);line-height:1;">{n}</p>
            <p style="font-size:0.875rem;color:rgba(255,255,255,0.7);margin-top:0.5rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section">
    <div class="container" style="max-width:760px;text-align:center;">
      <span class="section__eyebrow">Where We Work</span>
      <h2 class="section__title">Serving All of Kauai</h2>
      <p class="section__subtitle" style="margin-bottom:2.5rem;">
        From the North Shore to the South Shore, we proudly serve homeowners across the island.
      </p>
      <div class="service-areas">
        {settings.serviceAreas.map((area) => (
          <span class="service-area-badge">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Work With Us"
    title="Let's Build Something Together"
    subtitle="Reach out for a free estimate. No pressure, no obligation — just an honest conversation about your home."
    primaryLabel="Request a Free Estimate"
    secondaryLabel="Call Adam Directly"
    secondaryHref={phoneHref}
  />
</BaseLayout>
