---
import SEOPageLayout from '../components/SEOPageLayout.astro';
import settings from '../data/settings.json';

const phoneE164 = `+1${settings.phone.replace(/\D/g, '')}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Fence Contractor Kauai',
  description: 'Custom fence installation on Kauai. Cedar, ipe, hog wire, bamboo, chain link, and custom gates.',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Ad Value Home Improvement',
    telephone: phoneE164,
    areaServed: 'Kauai, Hawaii',
  },
  serviceType: 'Fence Installation',
};
---

<SEOPageLayout
  title="Fence Contractor Kauai"
  metaTitle="Fence Contractor Kauai | Cedar, Ipe & Hog Wire Fencing | Ad Value Home Improvement"
  metaDescription="Kauai's trusted fence contractor. Cedar, ipe hardwood, hog wire, bamboo, chain link, and custom gates. Free estimates. All of Kauai."
  eyebrow="Fencing · Kauai, Hawaii"
  pageTitle="Custom Fencing for Every Kauai Property"
  subtitle="Privacy, security, and beauty — built with the right materials for Hawaii's climate."
  imageSrc="/images/seo/fence-contractor.avif"
  imageAlt="Wood privacy fence installation around a residential yard"
  introTitle="Fences Designed for Island Conditions"
  intro="A quality fence adds privacy, security, and curb appeal — but in Hawaii, it has to be built to survive the elements. Ad Value Home Improvement installs custom fences using materials that are proven to hold up in Kauai's humid, salty, and wet environment. From classic cedar to premium ipe, hog wire panels to bamboo — we build fences that look great and last."
  highlights={[
    { icon: 'leaf', title: 'Material Expertise', description: 'We help you choose the right wood, metal, or composite for your property and climate.' },
    { icon: 'shield-check', title: 'Privacy & Security', description: 'Custom heights and styles to give you the privacy and peace of mind you deserve.' },
    { icon: 'paint-brush', title: 'Design Options', description: 'From classic board-on-board to modern hog wire — we match your home\'s style.' },
    { icon: 'building-office-2', title: 'Proper Installation', description: 'Correctly set posts and concrete footings ensure your fence stands for years.' },
  ]}
  serviceItems={[
    'Cedar Board-on-Board Fencing',
    'Ipe Hardwood Fencing',
    'Hog Wire Panel Fencing',
    'Bamboo Fencing',
    'Chain Link Fencing',
    'Custom Wood Gates',
    'Metal Gates & Hardware',
    'Privacy Fencing (6\' & 8\')',
    'Split Rail Fencing',
    'Fence Repairs & Replacement',
    'Post Setting & Footings',
    'Fence Staining & Sealing',
  ]}
  schema={schema}
/>
