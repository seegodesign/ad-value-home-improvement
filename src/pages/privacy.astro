---
import BaseLayout from '../layouts/BaseLayout.astro';
import ObfuscatedEmail from '../components/ObfuscatedEmail.astro';
---

<BaseLayout
  title="Privacy Policy | Ad Value Home Improvement Kauai"
  description="Privacy policy for Ad Value Home Improvement. How we collect and use information from our website visitors."
  noindex={true}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <h1 class="page-hero__title">Privacy Policy</h1>
      <p class="page-hero__subtitle">Last updated: 2025</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:780px;">
      <h2 style="font-size:1.5rem;color:var(--color-navy);margin-bottom:1rem;">Information We Collect</h2>
      <p style="color:var(--color-text-muted);line-height:1.75;margin-bottom:1.5rem;">
        When you fill out a form on this website (estimate request or contact form), we collect the information
        you provide: name, phone number, email address, project address, and project description. We use this
        information only to respond to your inquiry.
      </p>

      <h2 style="font-size:1.5rem;color:var(--color-navy);margin-bottom:1rem;">How We Use Your Information</h2>
      <p style="color:var(--color-text-muted);line-height:1.75;margin-bottom:1.5rem;">
        We use your contact information to respond to estimate requests and general inquiries. We do not sell,
        share, or distribute your personal information to third parties. We may use your email address to follow
        up on your project inquiry only.
      </p>

      <h2 style="font-size:1.5rem;color:var(--color-navy);margin-bottom:1rem;">Cookies & Analytics</h2>
      <p style="color:var(--color-text-muted);line-height:1.75;margin-bottom:1.5rem;">
        This website may use basic analytics (such as Google Analytics) to understand how visitors use the site.
        This data is anonymous and aggregated. No personally identifiable information is collected through analytics.
      </p>

      <h2 style="font-size:1.5rem;color:var(--color-navy);margin-bottom:1rem;">Contact</h2>
      <p style="color:var(--color-text-muted);line-height:1.75;">
        Questions about this privacy policy? Contact us at
        <ObfuscatedEmail email="info@advaluekauai.com" style="color:var(--color-green);" />.
      </p>
    </div>
  </section>
</BaseLayout>
