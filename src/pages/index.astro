---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ReviewCard from "../components/ReviewCard.astro";
import CTASection from "../components/CTASection.astro";
import services from "../data/services.json";
import reviews from "../data/reviews.json";
import galleryFences from "../data/gallery-fences.json";
import galleryDecksRailings from "../data/gallery-decks-railings.json";
import galleryFlooring from "../data/gallery-flooring.json";
import galleryCustom from "../data/gallery-custom.json";
import settings from "../data/settings.json";
import heroData from "../data/homepage.json";
import statsData from "../data/homepage-stats.json";
import servicesSection from "../data/homepage-services.json";
import aboutPreview from "../data/homepage-about.json";
import outcomesData from "../data/homepage-outcomes.json";
import gallerySection from "../data/homepage-gallery.json";
import reviewsSection from "../data/homepage-reviews.json";
import ctaSection from "../data/homepage-cta.json";

const featuredReviews = reviews.slice(0, 3);
const gallery = [
  ...galleryFences,
  ...galleryDecksRailings,
  ...galleryFlooring,
  ...galleryCustom,
];
const featuredGallery = gallery.slice(0, 8);

const serviceCardPhotos: Partial<Record<string, string>> = {
  decks: "/images/uploads/deck-builder.avif",
  carpentry: "/images/uploads/custom_1.avif",
  kitchens: "/images/uploads/kitchen-remodel.avif",
  bathrooms: "/images/uploads/bathroom-remodel.avif",
  drywall: "/images/uploads/drywall-repair.avif",
  fencing: "/images/uploads/fence-contractor.avif",
  maintenance: "/images/uploads/property-maintenance.avif",
  outdoor: "/images/uploads/outdoor-living.avif",
};

const phoneHref = `tel:+1${settings.phone.replace(/\D/g, "")}`;
---

<BaseLayout
  title={`${settings.businessName} | ${settings.tagline}`}
  description={`Kauai's trusted home improvement contractor since ${settings.foundedYear}. Decks, remodels, fencing, carpentry, property maintenance. Honest work, local values. Request a free estimate.`}
>
  <!-- Hero -->
  <Hero
    headline={heroData.headline}
    support={heroData.support}
    trustLine={heroData.trustLine}
    primaryCtaLabel={heroData.primaryCtaLabel}
    primaryCtaHref={heroData.primaryCtaHref}
    secondaryCtaLabel={heroData.secondaryCtaLabel}
    secondaryCtaHref={heroData.secondaryCtaHref}
    imageSrc={heroData.imageSrc}
    imageAlt={heroData.imageAlt}
    serviceTags={heroData.serviceTags}
  />

  <!-- Stats / Trust Bar -->
  <section class="trust-bar" aria-label="Key stats">
    <div class="container trust-bar__inner">
      {
        statsData.stats.map(({ number, label }, i) => (
          <>
            <div
              class="trust-bar__stat"
              data-motion={`motion-preset-fade-md motion-duration-700${i > 0 ? ` motion-delay-${i === 1 ? "150" : i === 2 ? "300" : "500"}` : ""}`}
            >
              <span class="trust-bar__number">{number}</span>
              <span class="trust-bar__label">{label}</span>
            </div>
            {i < statsData.stats.length - 1 && (
              <hr class="trust-bar__divider" aria-hidden="true" />
            )}
          </>
        ))
      }
    </div>
  </section>

  <!-- Services -->
  <section class="section" aria-labelledby="services-heading">
    <div class="container">
      <div
        class="section__header"
        data-motion="motion-preset-slide-up-sm motion-duration-700"
      >
        <span class="section__eyebrow">{servicesSection.eyebrow}</span>
        <h2 id="services-heading" class="section__title">
          {servicesSection.heading}
        </h2>
        <p class="section__subtitle">
          {servicesSection.subtitle}
        </p>
      </div>
      <div class="grid grid--4">
        {
          services.map((service) => (
            <ServiceCard
              title={service.title}
              description={service.description}
              items={service.items}
              imageSrc={serviceCardPhotos[service.id]}
              imageAlt={service.title}
              href={service.href}
            />
          ))
        }
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/services" class="btn btn--outline-navy btn--lg"
          >View All Services</a
        >
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="section section--sand" aria-labelledby="about-heading">
    <div class="container about-preview">
      <div
        class="about-preview__content"
        data-motion="motion-preset-slide-up-sm motion-duration-700"
      >
        <span class="section__eyebrow">{aboutPreview.eyebrow}</span>
        <h2 id="about-heading" class="section__title">
          {aboutPreview.heading}
        </h2>
        <blockquote class="about-preview__quote">
          "{aboutPreview.quote}"
        </blockquote>
        <p
          style="color:var(--color-text-muted);line-height:1.75;margin-bottom:1.5rem;"
        >
          {aboutPreview.body}
        </p>
        <div class="about-preview__signature">
          <div>
            <p class="about-preview__sig-name">{aboutPreview.sigName}</p>
            <p class="about-preview__sig-title">
              {aboutPreview.sigTitle}
            </p>
          </div>
        </div>
        <div style="margin-top:2rem;">
          <a href="/about" class="btn btn--secondary">Meet {settings.ownerName.split(' ')[0]} →</a>
        </div>
      </div>
      <div
        class="about-preview__image"
        data-motion="motion-preset-slide-up-sm motion-duration-700 motion-delay-150"
      >
        <div class="about-preview__photo-frame">
          <img
            src="/images/uploads/adam-marchacos.jpg"
            alt={`${settings.ownerName}, owner of ${settings.businessName}`}
            width="400"
            height="533"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="section" aria-labelledby="outcomes-heading">
    <div class="container">
      <div
        class="section__header"
        data-motion="motion-preset-slide-up-sm motion-duration-700"
      >
        <span class="section__eyebrow">{outcomesData.eyebrow}</span>
        <h2 id="outcomes-heading" class="section__title">
          {outcomesData.heading}
        </h2>
        <p class="section__subtitle">
          {outcomesData.subtitle}
        </p>
      </div>
      <div class="outcomes">
        {
          outcomesData.outcomes.map(({ id, title, color, items }, i) => (
            <div
              class={`outcome-card outcome-card--${color}`}
              data-motion={`motion-preset-slide-up-sm motion-duration-500${i > 0 ? ` motion-delay-${i === 1 ? "150" : i === 2 ? "300" : "500"}` : ""}`}
            >
              <div class="outcome-card__header">
                {/* <span class="outcome-card__icon" aria-hidden="true">{icon}</span> */}
                <h3 class="outcome-card__title">{title}</h3>
              </div>
              <div class="outcome-card__body">
                <ul class="outcome-card__list" role="list">
                  {items.map((item) => (
                    <li class="outcome-card__item">{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="section section--off-white" aria-labelledby="gallery-heading">
    <div class="container">
      <div
        class="section__header"
        data-motion="motion-preset-slide-up-sm motion-duration-700"
      >
        <span class="section__eyebrow">{gallerySection.eyebrow}</span>
        <h2 id="gallery-heading" class="section__title">{gallerySection.heading}</h2>
        <p class="section__subtitle">{gallerySection.subtitle}</p>
      </div>
      <div class="gallery-grid__items" style="margin-bottom:3rem;">
        {
          featuredGallery.map(({ title, category, image, description }) => (
            <div
              class="gallery-grid__item"
              data-motion="motion-preset-slide-up-sm motion-duration-500"
            >
              <div class="gallery-grid__image-wrap">
                <img
                  src={image}
                  alt={description || title}
                  class="gallery-grid__image"
                  width="400"
                  height="300"
                  loading="lazy"
                />
              </div>
              <div class="gallery-grid__caption">
                <span class="gallery-grid__category">{category}</span>
                <p class="gallery-grid__label">{title}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div style="text-align:center;">
        <a href="/gallery" class="btn btn--outline-navy btn--lg"
          >View Full Gallery</a
        >
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section--sand" aria-labelledby="reviews-heading">
    <div class="container">
      <div
        class="section__header"
        data-motion="motion-preset-slide-up-sm motion-duration-700"
      >
        <span class="section__eyebrow">{reviewsSection.eyebrow}</span>
        <h2 id="reviews-heading" class="section__title">
          {reviewsSection.heading}
        </h2>
        <p class="section__subtitle">
          {reviewsSection.subtitle}
        </p>
      </div>
      <div class="grid grid--3">
        {
          featuredReviews.map((review) => (
            <ReviewCard
              name={review.name}
              neighborhood={review.neighborhood}
              text={review.text}
              photo={review.photo}
              stars={review.stars}
            />
          ))
        }
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/reviews" class="btn btn--outline-navy btn--lg"
          >Read All Reviews</a
        >
      </div>
    </div>
  </section>

  <!-- Aloha Home Care Plan -->
  {
    /*
    <section class="section" aria-labelledby="care-plan-heading">
      <div class="container">
        <div class="care-plan" data-motion="motion-preset-fade-md motion-duration-700">
          <p class="care-plan__eyebrow">New: Recurring Service</p>
          <h2 id="care-plan-heading" class="care-plan__title">
            The Aloha Home Care Plan
          </h2>
          <p class="care-plan__description">
            Your home deserves year-round attention. Our membership plan keeps your property
            in top condition — before small issues become expensive problems.
          </p>
          <div class="care-plan__includes">
            {[
              'Gutter cleaning & clearing',
              'Exterior property inspections',
              'Deck condition inspection',
              'Fence & gate inspection',
              'Pressure washing discounts',
              'Priority scheduling',
              'Storm damage checkups',
            ].map((item) => (
              <div class="care-plan__include-item">{item}</div>
            ))}
          </div>
          <div class="care-plan__plans">
            {[
              { name: 'Monthly', label: 'Ongoing peace of mind' },
              { name: 'Quarterly', label: 'Seasonal check-ins', featured: true },
              { name: 'Annual', label: 'One visit per year' },
            ].map(({ name, label, featured }) => (
              <div class={`care-plan__plan${featured ? ' care-plan__plan--featured' : ''}`}>
                <p class="care-plan__plan-name">{name}</p>
                <p class="care-plan__plan-label">{label}</p>
              </div>
            ))}
          </div>
          <a href="/contact#care-plan" class="btn btn--primary btn--lg">
            Learn More
          </a>
        </div>
      </div>
    </section>
    */
  }

  <!-- Final CTA -->
  <CTASection
    eyebrow={ctaSection.eyebrow}
    title={ctaSection.title}
    subtitle={ctaSection.subtitle}
    primaryLabel={ctaSection.primaryLabel}
    secondaryLabel={`${ctaSection.secondaryLabel} ${settings.phone}`}
    secondaryHref={phoneHref}
    note={ctaSection.note}
  />
</BaseLayout>
