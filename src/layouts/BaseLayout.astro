---
import "../styles/global.css";
import "../styles/motion.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import settings from "../data/settings.json";
import services from "../data/services.json";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/images/og-default.jpg",
  canonical,
  schema,
  noindex = false,
} = Astro.props;

const siteUrl = "https://advaluekauai.com";
const canonicalUrl =
  canonical || new URL(Astro.url.pathname, siteUrl).toString();
const phoneE164 = `+1${settings.phone.replace(/\D/g, "")}`;

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "@id": siteUrl,
  name: "Ad Value Home Improvement",
  description:
    "Kauai's trusted home improvement partner. Decks, remodels, fencing, carpentry, and property maintenance.",
  url: siteUrl,
  telephone: phoneE164,
  email: "info@advaluekauai.com",
  logo: `${siteUrl}/images/logo.svg`,
  image: `${siteUrl}/images/og-default.jpg`,
  foundingDate: "2019",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Lihue",
    addressRegion: "HI",
    postalCode: "96766",
    addressCountry: "US",
  },
  areaServed: settings.serviceAreas.map((area) => ({
    "@type": "City",
    name: area,
    containedInPlace: { "@type": "State", name: "Hawaii" },
  })),
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Home Improvement Services",
    itemListElement: services.map((s) => ({
      "@type": "Offer",
      itemOffered: { "@type": "Service", name: s.title },
    })),
  },
  openingHoursSpecification: settings.openingHoursSpecification,
  priceRange: "$$",
  // TODO: Add reviews when we have them
  // aggregateRating: {
  //   "@type": "AggregateRating",
  //   ratingValue: "5",
  //   reviewCount: "47",
  //   bestRating: "5",
  // },
};

const schemas = [
  defaultSchema,
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ad Value Home Improvement" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    {
      schemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }
  </head>
  <body>
    <a href="#main-content" class="sr-only">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      // Trigger motion-preset classes when elements enter the viewport
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const classes = (el.dataset.motion || "")
                .trim()
                .split(/\s+/)
                .filter(Boolean);
              if (classes.length) {
                // Remove inline hide before adding animation so the
                // animation keyframes fully control opacity
                el.style.opacity = "";
                el.classList.add(...classes);
              }
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px -40px 0px" },
      );
      document.querySelectorAll("[data-motion]").forEach((el) => {
        // Hide via inline style so CSS animations can cleanly override it
        (el as HTMLElement).style.opacity = "0";
        observer.observe(el);
      });
    </script>
  </body>
</html>
