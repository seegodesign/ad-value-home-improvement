---
interface Props {
  headline?: string;
  support?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  headline = "Kauai's Trusted Home Improvement Partner.",
  support = "Building excellent projects on Kauai since 2019. Building Better Relationships.",
  imageSrc = "/images/brand-illustration.webp",
  imageAlt = "Ad Value Home Improvement project on Kauai",
} = Astro.props;

const serviceTags = [
  { label: 'Repairs',              href: '/handyman-kauai' },
  { label: 'Remodels',             href: '/services' },
  { label: 'Decks',                href: '/deck-builder-kauai' },
  { label: 'Fencing',              href: '/fence-contractor-kauai' },
  { label: 'Custom Carpentry',     href: '/custom-carpentry-kauai' },
  { label: 'Property Maintenance', href: '/property-maintenance-kauai' },
];
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__inner">
    <!-- Content -->
    <div class="hero__content">
      <h1 id="hero-heading" class="hero__headline motion-preset-slide-up-md motion-duration-700">
        {
          headline.includes("Kauai's Trusted") ? (
            <>
              Kauai's <span class="hero__headline-gradient">Trusted</span> Home Improvement Partner.
            </>
          ) : (
            headline
          )
        }
      </h1>
      <p class="hero__subheadline motion-preset-slide-up-md motion-duration-700 motion-delay-150">{support}</p>

      <div class="hero__services motion-preset-fade-md motion-duration-500 motion-delay-500">
        {serviceTags.map(({ label, href }) => (
          <a href={href} class="hero__service-tag">{label}</a>
        ))}
      </div>

      <div class="hero__actions motion-preset-slide-up-md motion-duration-500 motion-delay-500">
        <a href="/estimate" class="btn btn--primary btn--lg">
          Request a Free Estimate
        </a>
        <a href="/services" class="btn btn--outline-white btn--lg">
          View Our Services
        </a>
      </div>

      <p class="hero__trust motion-preset-fade-md motion-duration-500 motion-delay-700">
        <div class="hero__trust-stars">★★★★★</div>
        Trusted by homeowners across Kauai.
      </p>
    </div>

    <!-- Image -->
    <div class="hero__image motion-preset-slide-up-md motion-duration-700 motion-delay-300">
      <div class="hero__brand-illustration">
        <img
          src={imageSrc}
          alt={imageAlt}
          width="600"
          height="450"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
