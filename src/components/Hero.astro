---
interface Props {
  headline?: string;
  support?: string;
  trustLine?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
  serviceTags?: { label: string; href: string }[];
}

const {
  headline,
  support,
  trustLine,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  imageSrc,
  imageAlt,
  serviceTags = [],
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__inner">
    <!-- Content -->
    <div class="hero__content">
      <h1 id="hero-heading" class="hero__headline motion-preset-slide-up-md motion-duration-700">
        {headline}
      </h1>
      <p class="hero__subheadline motion-preset-slide-up-md motion-duration-700 motion-delay-150">{support}</p>

      <div class="hero__services motion-preset-fade-md motion-duration-500 motion-delay-500">
        {serviceTags.map(({ label, href }) => (
          <a href={href} class="hero__service-tag">{label}</a>
        ))}
      </div>

      <div class="hero__actions motion-preset-slide-up-md motion-duration-500 motion-delay-500">
        <a href={primaryCtaHref} class="btn btn--primary btn--lg">
          {primaryCtaLabel}
        </a>
        <a href={secondaryCtaHref} class="btn btn--outline-white btn--lg">
          {secondaryCtaLabel}
        </a>
      </div>

      <p class="hero__trust motion-preset-fade-md motion-duration-500 motion-delay-700">
        <div class="hero__trust-stars">★★★★★</div>
        {trustLine}
      </p>
    </div>

    <!-- Image -->
    <div class="hero__image motion-preset-slide-up-md motion-duration-700 motion-delay-300">
      <div class="hero__brand-illustration">
        <img
          src={imageSrc}
          alt={imageAlt}
          width="600"
          height="450"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
