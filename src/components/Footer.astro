---
import settings from '../data/settings.json';
import ObfuscatedEmail from './ObfuscatedEmail.astro';

const quickLinks = [
  { label: 'Home',             href: '/' },
  { label: 'About',            href: '/about' },
  { label: 'Services',         href: '/services' },
  { label: 'Gallery',          href: '/gallery' },
  { label: 'Reviews',          href: '/reviews' },
  { label: 'Request Estimate', href: '/estimate' },
  { label: 'Contact',          href: '/contact' },
];

const seoPageFiles = await import.meta.glob('../data/seo-pages/*.json');
const seoPages = await Promise.all(
  Object.entries(seoPageFiles).map(async ([filePath, resolver]) => {
    const data = (await resolver()) as { title: string };
    const slug = filePath.replace('../data/seo-pages/', '').replace('.json', '');
    return { label: data.title, href: `/${slug}` };
  })
);

const year = new Date().getFullYear();
const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
---

<footer class="footer" role="contentinfo">
  <div class="footer__top">
    <div class="container footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href="/" aria-label={`${settings.businessName} — Home`}>
          <img
            src="/images/logo-light.svg"
            alt={settings.businessName}
            class="footer__logo-img"
            width="200"
            height="48"
          />
        </a>
        <p class="footer__tagline">
          {settings.tagline} since {settings.foundedYear}.
          Honest work, skilled hands, island values.
        </p>
        <!-- <div class="footer__social">
          <a href={socialLinks.facebook} class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">f</a>
          <a href={socialLinks.instagram} class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">ig</a>
          <a href={socialLinks.nextdoor} class="footer__social-link" aria-label="Nextdoor" target="_blank" rel="noopener noreferrer">nd</a>
        </div> -->
      </div>

      <!-- Quick Links -->
      <div class="footer__column">
        <span class="footer__column-title">Quick Links</span>
        <ul class="footer__list" role="list">
          {quickLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="footer__link">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer__column">
        <span class="footer__column-title">Services</span>
        <ul class="footer__list" role="list">
          {seoPages.map(({ label, href }) => (
            <li>
              <a href={href} class="footer__link">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__column">
        <span class="footer__column-title">Contact</span>
        <div class="footer__contact-item">
          <span class="icon-mask icon-phone footer__contact-icon" aria-hidden="true"></span>
          <a href={phoneHref}>{settings.phone}</a>
        </div>
        <div class="footer__contact-item">
          <span class="icon-mask icon-email footer__contact-icon" aria-hidden="true"></span>
          <ObfuscatedEmail email={settings.email} />
        </div>
        <div class="footer__contact-item">
          <span class="icon-mask icon-location footer__contact-icon" aria-hidden="true"></span>
          <span>Kapaa, Hawaii 96746</span>
        </div>
        <div class="footer__contact-item">
          <span class="icon-mask icon-clock footer__contact-icon" aria-hidden="true"></span>
          <span>Mon–Fri: {settings.hours.weekdays}<br/>Sat: {settings.hours.saturday}<br/>Sun: {settings.hours.sunday}</span>
        </div>
        <div style="margin-top:1.5rem;">
          <a href="/estimate" class="btn btn--primary btn--sm btn--full">
            Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">
        &copy; {year} {settings.businessName}. All rights reserved.
        Site by <a href="https://seegodesign.com" class="footer__bottom-link" target="_blank" rel="noopener noreferrer">Seego Design</a>.
      </p>
      <div class="footer__bottom-links">
        <a href="/privacy" class="footer__bottom-link">Privacy Policy</a>
        <a href="/sitemap.xml" class="footer__bottom-link">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
