---
interface Props {
  title: string;
  description: string;
  items: string[];
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  linkLabel?: string;
  featured?: boolean;
}

const {
  title,
  description,
  items,
  imageSrc,
  imageAlt,
  href,
  linkLabel = 'Learn More →',
  featured = false,
} = Astro.props;

const cardImageSrc = imageSrc || '/images/placeholder-project.svg';
const cardImageAlt = imageAlt || `${title} project photo`;
---

<div class={`service-card${featured ? ' service-card--featured' : ''}`} data-motion="motion-preset-slide-up-sm motion-duration-500">
  <div class="service-card__media">
    <img
      src={cardImageSrc}
      alt={cardImageAlt}
      class="service-card__media-image"
      loading="lazy"
      width="640"
      height="360"
    />
  </div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__description">{description}</p>
  <ul class="service-card__list" role="list">
    {items.slice(0, 6).map((item) => (
      <li class="service-card__list-item">{item}</li>
    ))}
    {items.length > 6 && (
      <li class="service-card__list-item">+ {items.length - 6} more</li>
    )}
  </ul>
  {href && (
    <a href={href} class="service-card__link">{linkLabel}</a>
  )}
</div>

<style>
  .service-card__media {
    margin: calc(var(--sp-8) * -1) calc(var(--sp-8) * -1) var(--sp-6);
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-gray-200);
    background: var(--color-gray-100);
  }

  .service-card__media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-card--featured {
    border-color: var(--color-green);
    box-shadow: var(--shadow-md);
  }
</style>
