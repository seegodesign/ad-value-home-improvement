---
interface Props {
  name: string;
  neighborhood: string;
  text: string;
  photo?: string;
  stars?: number;
}

const {
  name,
  neighborhood,
  text,
  photo = '/images/placeholder-person.svg',
  stars = 5,
} = Astro.props;
---

<article class="review-card" aria-label={`Review by ${name}`} data-motion="motion-preset-slide-up-sm motion-duration-500">
  <div class="review-card__stars" aria-label={`${stars} out of 5 stars`}>
    {Array.from({ length: stars }).map(() => <span aria-hidden="true">★</span>)}
  </div>
  <p class="review-card__text">{text}</p>
  <div class="review-card__author">
    <div class="review-card__author-info">
      <p class="review-card__author-name">{name}</p>
      <p class="review-card__author-location">{neighborhood}, Kauai</p>
    </div>
  </div>
</article>
