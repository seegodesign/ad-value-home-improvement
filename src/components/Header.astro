---
import services from '../data/services.json';
import settings from '../data/settings.json';

const navLinks = [
  { label: 'Home',     href: '/' },
  { label: 'About',    href: '/about' },
  { label: 'Gallery',  href: '/gallery' },
  { label: 'Reviews',  href: '/reviews' },
  { label: 'Contact',  href: '/contact' },
];

const currentPath = Astro.url.pathname;
const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
---

<header class="header" role="banner">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Ad Value Home Improvement — Home">
      <img
        src="/images/logo-compact.svg"
        alt="Ad Value Home Improvement"
        class="header__logo-img"
        width="330"
        height="66"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list" role="list">
        {navLinks.slice(0, 2).map(({ label, href }) => (
          <li class="header__nav-item">
            <a
              href={href}
              class={`header__nav-link${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? ' header__nav-link--active' : ''}`}
            >
              {label}
            </a>
          </li>
        ))}

        <!-- Services dropdown -->
        <li class="header__nav-item header__nav-item--dropdown">
          <button
            class={`header__nav-link header__nav-link--dropdown-trigger${currentPath.startsWith('/services') || services.some(s => currentPath === s.href) ? ' header__nav-link--active' : ''}`}
            aria-expanded="false"
            aria-haspopup="true"
          >
            Services
            <svg class="header__dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="header__dropdown" role="region">
            <ul class="header__dropdown-list" role="list">
              {services.map((service) => (
                <li>
                  <a href={service.href} class="header__dropdown-link">
                    {service.title}
                  </a>
                </li>
              ))}
            </ul>
            <a href="/services" class="header__dropdown-footer">View All Services →</a>
          </div>
        </li>

        {navLinks.slice(2).map(({ label, href }) => (
          <li class="header__nav-item">
            <a
              href={href}
              class={`header__nav-link${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? ' header__nav-link--active' : ''}`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <div class="header__actions">
      <a href={phoneHref} class="header__phone" aria-label="Call us">
        <span class="icon-mask icon-phone icon-sm" aria-hidden="true"></span>
        <span>{settings.phone}</span>
      </a>
      <a href="/estimate" class="btn btn--primary btn--sm">Request Estimate</a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      class="header__hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
    </button>
  </div>
</header>

<!-- Mobile Nav Overlay -->
<nav
  id="mobile-nav"
  class="mobile-nav"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="mobile-nav__header">
    <a href="/" class="mobile-nav__logo-link" aria-label="Ad Value Home Improvement — Home">
      <img
        src="/images/logo-compact.svg"
        alt="Ad Value Home Improvement"
        class="mobile-nav__logo-img"
        width="180"
        height="40"
      />
    </a>
    <button
      class="mobile-nav__close"
      aria-label="Close navigation menu"
    >
      ✕
    </button>
  </div>

  <ul class="mobile-nav__list" role="list">
    {navLinks.slice(0, 2).map(({ label, href }) => (
      <li>
        <a href={href} class="mobile-nav__link">{label}</a>
      </li>
    ))}

    <!-- Mobile Services accordion -->
    <li class="mobile-nav__accordion">
      <button class="mobile-nav__link mobile-nav__accordion-trigger" aria-expanded="false">
        Services
        <svg class="mobile-nav__accordion-chevron" width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <ul class="mobile-nav__sub" role="list" hidden>
        {services.map((service) => (
          <li>
            <a href={service.href} class="mobile-nav__sub-link">{service.title}</a>
          </li>
        ))}
        <li>
          <a href="/services" class="mobile-nav__sub-link mobile-nav__sub-link--all">View All Services →</a>
        </li>
      </ul>
    </li>

    {navLinks.slice(2).map(({ label, href }) => (
      <li>
        <a href={href} class="mobile-nav__link">{label}</a>
      </li>
    ))}
  </ul>

  <a href="/estimate" class="btn btn--primary btn--full mobile-nav__cta">
    Request a Free Estimate
  </a>

  <div class="mobile-nav__contact">
    <p><span class="icon-mask icon-phone icon-sm" style="margin-right:0.375rem;" aria-hidden="true"></span><a href={phoneHref}>{settings.phone}</a></p>
    <p style="margin-top:0.5rem;"><span class="icon-mask icon-email icon-sm" style="margin-right:0.375rem;" aria-hidden="true"></span><a href="mailto:info@advaluekauai.com">info@advaluekauai.com</a></p>
  </div>
</nav>

<style>
  .header__phone {
    display: none;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    transition: color var(--transition);
  }

  .header__phone:hover { color: var(--color-green); }

  @media (min-width: 1024px) {
    .header__phone { display: flex; }
  }

  /* ---- Desktop dropdown ---- */
  .header__nav-item--dropdown {
    position: relative;
  }

  .header__nav-link--dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    padding: var(--sp-6) var(--sp-3);
    transition: color var(--transition);
  }

  .header__nav-link--dropdown-trigger:hover,
  .header__nav-item--dropdown:hover .header__nav-link--dropdown-trigger,
  .header__nav-link--dropdown-trigger[aria-expanded="true"] {
    color: var(--color-green);
  }

  .header__dropdown-chevron {
    transition: transform var(--transition);
    flex-shrink: 0;
    color: currentColor;
  }

  .header__nav-item--dropdown:hover .header__dropdown-chevron,
  .header__nav-link--dropdown-trigger[aria-expanded="true"] .header__dropdown-chevron {
    transform: rotate(180deg);
  }

  /* Invisible bridge fills the gap so cursor doesn't leave the li */
  .header__dropdown::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }

  .header__dropdown {
    position: absolute;
    top: calc(100% + 2px);
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-bottom-left-radius: var(--radius-lg);
    border-bottom-right-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--sp-3) 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity var(--transition), visibility var(--transition), transform var(--transition);
    transform: translateX(-50%) translateY(-6px);
    z-index: 200;
  }

  .header__nav-item--dropdown:hover .header__dropdown,
  .header__nav-item--dropdown:focus-within .header__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .header__dropdown-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__dropdown-link {
    display: block;
    padding: var(--sp-2) var(--sp-5);
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    transition: background-color var(--transition), color var(--transition);
    white-space: nowrap;
  }

  .header__dropdown-link:hover {
    background-color: var(--color-green-light);
    color: white;
  }

  .header__dropdown-footer {
    display: block;
    padding: var(--sp-2) var(--sp-5);
    margin-top: var(--sp-2);
    border-top: 1px solid var(--color-gray-200);
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    color: var(--color-green);
    transition: color var(--transition);
  }

  .header__dropdown-footer:hover {
    color: var(--color-green-dark);
  }

  /* ---- Mobile accordion ---- */
  .mobile-nav__accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    text-align: left;
  }

  .mobile-nav__accordion-chevron {
    flex-shrink: 0;
    transition: transform var(--transition);
    color: currentColor;
  }

  .mobile-nav__accordion-trigger[aria-expanded="true"] .mobile-nav__accordion-chevron {
    transform: rotate(180deg);
  }

  .mobile-nav__sub {
    list-style: none;
    margin: 0;
    padding: var(--sp-2) 0 var(--sp-3) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .mobile-nav__sub[hidden] {
    display: none;
  }

  .mobile-nav__sub-link {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: var(--fw-semibold);
    color: rgba(255,255,255,0.75);
    padding: var(--sp-2) var(--sp-2);
    transition: color var(--transition);
  }

  .mobile-nav__sub-link:hover {
    color: var(--color-brown-light);
  }

  .mobile-nav__sub-link--all {
    color: var(--color-green-light);
    margin-top: var(--sp-1);
  }
</style>

<script>
  const header    = document.querySelector('.header') as HTMLElement;
  const hamburger = header?.querySelector('.header__hamburger') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
  const closeBtn  = mobileNav?.querySelector('.mobile-nav__close') as HTMLButtonElement;
  const accordionTrigger = mobileNav?.querySelector('.mobile-nav__accordion-trigger') as HTMLButtonElement;
  const accordionSub     = mobileNav?.querySelector('.mobile-nav__sub') as HTMLElement;

  // Prevent duplicate listeners if this script is evaluated more than once.
  if (header?.dataset.navBound === 'true') {
    // Already bound, do nothing.
  } else {
    if (header) header.dataset.navBound = 'true';

    function openNav() {
      mobileNav.classList.add('mobile-nav--open');
      mobileNav.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.classList.add('header__hamburger--open');
      document.body.style.overflow = 'hidden';
    }

    function closeNav() {
      mobileNav.classList.remove('mobile-nav--open');
      mobileNav.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('header__hamburger--open');
      document.body.style.overflow = '';

      // Reset accordion to collapsed whenever nav closes.
      if (accordionTrigger && accordionSub) {
        accordionTrigger.setAttribute('aria-expanded', 'false');
        accordionSub.hidden = true;
      }
    }

    hamburger?.addEventListener('click', () => {
      hamburger.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
    });

    closeBtn?.addEventListener('click', closeNav);

    mobileNav?.querySelectorAll('.mobile-nav__link:not(.mobile-nav__accordion-trigger), .mobile-nav__cta, .mobile-nav__sub-link').forEach((link) => {
      link.addEventListener('click', closeNav);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeNav();
    });

    accordionTrigger?.addEventListener('click', () => {
      const expanded = accordionTrigger.getAttribute('aria-expanded') === 'true';
      accordionTrigger.setAttribute('aria-expanded', String(!expanded));
      accordionSub.hidden = expanded;
    });
  }
</script>
