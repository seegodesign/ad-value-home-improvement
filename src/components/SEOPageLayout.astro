---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from './CTASection.astro';
import settings from '../data/settings.json';

interface Highlight {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
  eyebrow: string;
  pageTitle: string;
  subtitle: string;
  introTitle: string;
  intro: string;
  highlights: Highlight[];
  serviceItems?: string[];
  imageSrc?: string;
  imageAlt?: string;
  schema?: object;
}

const {
  title,
  metaTitle,
  metaDescription,
  eyebrow,
  pageTitle,
  subtitle,
  introTitle,
  intro,
  highlights,
  serviceItems = [],
  imageSrc = '/images/placeholder-project.svg',
  imageAlt = 'Home improvement project on Kauai',
  schema,
} = Astro.props;
const phoneHref = `tel:+1${settings.phone.replace(/\D/g, '')}`;
---

<BaseLayout title={metaTitle} description={metaDescription} schema={schema}>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>
      <p class="page-hero__eyebrow">{eyebrow}</p>
      <h1 class="page-hero__title">{pageTitle}</h1>
      <p class="page-hero__subtitle">{subtitle}</p>
    </div>
  </section>

  <!-- Intro + Image -->
  <section class="section">
    <div class="container seo-page__intro">
      <div class="seo-page__content">
        <h2 class="seo-page__intro-title">{introTitle}</h2>
        <p style="font-size:1.1rem;line-height:1.75;margin-bottom:2rem;color:var(--color-text-muted);">
          {intro}
        </p>

        {highlights.length > 0 && (
          <div class="seo-page__highlights">
            {highlights.map(({ icon, title: htitle, description }) => (
              <div class="seo-page__highlight">
                <div class="seo-page__highlight-icon" aria-hidden="true">
                  <span class="icon-mask" style={`-webkit-mask-image:url('/icons/${icon}.svg');mask-image:url('/icons/${icon}.svg');width:24px;height:24px;`}></span>
                </div>
                <div class="seo-page__highlight-content">
                  <h4>{htitle}</h4>
                  <p>{description}</p>
                </div>
              </div>
            ))}
          </div>
        )}

        <a href="/estimate" class="btn btn--primary btn--lg">
          Get a Free Estimate
        </a>
      </div>

      <div class="seo-page__image">
        <div style="border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:4/3;background:var(--color-sand);">
          <img
            src={imageSrc}
            alt={imageAlt}
            width="560"
            height="420"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services List -->
  {serviceItems.length > 0 && (
    <section class="section section--sand">
      <div class="container">
        <div class="section__header">
          <span class="section__eyebrow">What We Do</span>
          <h2 class="section__title">Our {title} Services</h2>
        </div>
        <div class="grid grid--3">
          {serviceItems.map((item, index) => (
            <div
              class="seo-service-item"
              style={`--service-delay:${index * 120}ms;`}
              data-motion="motion-preset-slide-up-sm motion-duration-500"
            >
              <span class="seo-service-item__icon" aria-hidden="true">
                <span class="icon-mask icon-check seo-service-item__icon-base"></span>
                <span class="seo-service-item__icon-fill-wrap">
                  <span class="icon-mask icon-check seo-service-item__icon-fill"></span>
                </span>
              </span>
              <span class="seo-service-item__label">
                <span class="seo-service-item__text seo-service-item__text--base">{item}</span>
                <span class="seo-service-item__text-fill-wrap" aria-hidden="true">
                  <span class="seo-service-item__text seo-service-item__text--fill">{item}</span>
                </span>
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container" style="max-width:var(--max-width);">
      <div class="section__header">
        <span class="section__eyebrow">Why Ad Value</span>
        <h2 class="section__title">Why Kauai Homeowners Trust Us</h2>
      </div>
      <div style="display:grid;gap:1.5rem;">
        {[
          { icon: 'hand-raised', title: 'Honest Communication', desc: 'Adam answers his own phone and communicates clearly from estimate to completion.' },
          { icon: 'wrench-screwdriver', title: 'Quality Craftsmanship', desc: 'Every project is built to last Hawaii\'s climate — humid, salty, and demanding.' },
          { icon: 'calendar-days', title: 'We Show Up', desc: 'We respect your time. When we say we\'ll be there, we\'re there.' }
        ].map(({ icon, title: wtitle, desc }) => (
          <div style="display:flex;gap:1.25rem;align-items:flex-start;padding:1.5rem;background:var(--color-off-white);border-radius:var(--radius-lg);border:1px solid var(--color-gray-200);">
            <span class="icon-mask" style={`-webkit-mask-image:url('/icons/${icon}.svg');mask-image:url('/icons/${icon}.svg');width:28px;height:28px;color:var(--color-navy);flex-shrink:0;`} aria-hidden="true"></span>
            <div>
              <h4 style="font-family:var(--font-heading);font-size:1.3rem;font-weight:700;color:var(--color-navy);margin-bottom:0.375rem;">{wtitle}</h4>
              <p style="color:var(--color-text-muted);margin:0;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Ready to Start?"
    title="Get a Free Estimate Today"
    subtitle="No pressure. No obligation. Just an honest conversation about your project."
    primaryLabel="Request a Free Estimate"
    secondaryLabel={settings.phone}
    secondaryHref={phoneHref}
    note="★★★★★ Trusted by Kauai homeowners since 2019"
  />
</BaseLayout>
