---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from './CTASection.astro';

interface Highlight {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
  eyebrow: string;
  pageTitle: string;
  subtitle: string;
  intro: string;
  highlights: Highlight[];
  serviceItems?: string[];
  imageSrc?: string;
  imageAlt?: string;
  schema?: object;
}

const {
  title,
  metaTitle,
  metaDescription,
  eyebrow,
  pageTitle,
  subtitle,
  intro,
  highlights,
  serviceItems = [],
  imageSrc = '/images/placeholder-project.svg',
  imageAlt = 'Home improvement project on Kauai',
  schema,
} = Astro.props;
---

<BaseLayout title={metaTitle} description={metaDescription} schema={schema}>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container page-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Home</a>
        <span class="breadcrumb__separator" aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>
      <p class="page-hero__eyebrow">{eyebrow}</p>
      <h1 class="page-hero__title">{pageTitle}</h1>
      <p class="page-hero__subtitle">{subtitle}</p>
      <div class="page-hero__accent-bar" aria-hidden="true"></div>
    </div>
  </section>

  <!-- Intro + Image -->
  <section class="section">
    <div class="container seo-page__intro">
      <div class="seo-page__content">
        <span class="accent-bar" aria-hidden="true"></span>
        <p style="font-size:1.1rem;line-height:1.75;margin-bottom:2rem;color:var(--color-text-muted);">
          {intro}
        </p>

        {highlights.length > 0 && (
          <div class="seo-page__highlights">
            {highlights.map(({ icon, title: htitle, description }) => (
              <div class="seo-page__highlight">
                <div class="seo-page__highlight-icon" aria-hidden="true">{icon}</div>
                <div class="seo-page__highlight-content">
                  <h4>{htitle}</h4>
                  <p>{description}</p>
                </div>
              </div>
            ))}
          </div>
        )}

        <a href="/estimate" class="btn btn--primary btn--lg">
          Get a Free Estimate
        </a>
      </div>

      <div class="seo-page__image">
        <div style="border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:4/3;background:var(--color-sand);">
          <img
            src={imageSrc}
            alt={imageAlt}
            width="560"
            height="420"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services List -->
  {serviceItems.length > 0 && (
    <section class="section section--sand">
      <div class="container">
        <div class="section__header">
          <span class="section__eyebrow">What We Do</span>
          <h2 class="section__title">Our {title} Services</h2>
        </div>
        <div class="grid grid--3">
          {serviceItems.map((item) => (
            <div style="display:flex;align-items:center;gap:0.75rem;background:white;padding:1rem 1.25rem;border-radius:var(--radius);box-shadow:var(--shadow-xs);border:1px solid var(--color-gray-200);">
              <span style="color:var(--color-green);font-weight:700;flex-shrink:0;">✓</span>
              <span style="font-size:0.9375rem;font-weight:500;color:var(--color-text);">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <div class="section__header">
        <span class="section__eyebrow">Why Ad Value</span>
        <h2 class="section__title">Why Kauai Homeowners Trust Us</h2>
      </div>
      <div style="display:grid;gap:1.5rem;">
        {[
          { icon: '🤝', title: 'Honest Communication', desc: 'Adam answers his own phone and communicates clearly from estimate to completion.' },
          { icon: '🔨', title: 'Quality Craftsmanship', desc: 'Every project is built to last Hawaii\'s climate — humid, salty, and demanding.' },
          { icon: '📅', title: 'We Show Up', desc: 'We respect your time. When we say we\'ll be there, we\'re there.' },
          { icon: '🏝️', title: 'Local & Licensed', desc: 'Kauai-based since 2019. Licensed, insured, and proud to serve this community.' },
        ].map(({ icon, title: wtitle, desc }) => (
          <div style="display:flex;gap:1.25rem;align-items:flex-start;padding:1.5rem;background:var(--color-off-white);border-radius:var(--radius-lg);border:1px solid var(--color-gray-200);">
            <span style="font-size:1.75rem;flex-shrink:0;" aria-hidden="true">{icon}</span>
            <div>
              <h4 style="font-family:var(--font-heading);font-size:1rem;font-weight:700;color:var(--color-navy);margin-bottom:0.375rem;">{wtitle}</h4>
              <p style="font-size:0.9375rem;color:var(--color-text-muted);margin:0;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Ready to Start?"
    title="Get a Free Estimate Today"
    subtitle="No pressure. No obligation. Just an honest conversation about your project."
    primaryLabel="Request a Free Estimate"
    secondaryLabel="(808) 555-1234"
    secondaryHref="tel:+18085551234"
    note="★★★★★ Trusted by Kauai homeowners since 2019"
  />
</BaseLayout>
