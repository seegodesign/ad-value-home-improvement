<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" role="img" aria-label="Ad Value Home Improvement — Kauai's Trusted Home Improvement Partner">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#071f3d"/>
      <stop offset="100%" style="stop-color:#0B2F56"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <!-- Accent bar -->
  <rect x="0" y="0" width="8" height="630" fill="#5A8F29"/>
  <!-- Logo mark -->
  <rect x="80" y="180" width="90" height="90" rx="10" fill="#0B2F56" stroke="#5A8F29" stroke-width="2"/>
  <polygon points="125,195 160,225 155,225 155,260 95,260 95,225 90,225" fill="#5A8F29"/>
  <rect x="116" y="235" width="18" height="25" fill="#FFFFFF"/>
  <!-- Business Name -->
  <text x="190" y="225" font-family="Montserrat, sans-serif" font-weight="800" font-size="52" fill="#FFFFFF" letter-spacing="2">AD VALUE</text>
  <text x="190" y="268" font-family="Montserrat, sans-serif" font-weight="600" font-size="28" fill="#5A8F29" letter-spacing="3">HOME IMPROVEMENT</text>
  <!-- Tagline -->
  <text x="80" y="340" font-family="Open Sans, sans-serif" font-size="22" fill="rgba(255,255,255,0.75)">Kauai's Trusted Home Improvement Partner</text>
  <!-- Divider -->
  <rect x="80" y="370" width="600" height="2" fill="#B9854D"/>
  <!-- Subtext -->
  <text x="80" y="410" font-family="Open Sans, sans-serif" font-size="18" fill="rgba(255,255,255,0.5)">Decks  •  Remodels  •  Fencing  •  Custom Carpentry  •  Property Maintenance</text>
  <text x="80" y="445" font-family="Montserrat, sans-serif" font-weight="600" font-size="15" fill="#B9854D">★★★★★  Licensed &amp; Insured  •  Kauai, Hawaii  •  Est. 2019</text>
</svg>
